{
  "name": "stocksys-backend",
  "version": "1.0.0",
  "description": "StockSys Multi-Shop Inventory & Billing API",
  "main": "dist/server.js",
  "scripts": {
    "dev":        "ts-node-dev --respawn --transpile-only src/server.ts",
    "build":      "tsc",
    "start":      "node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:push":    "prisma db push",
    "db:seed":    "ts-node prisma/seed.ts",
    "db:studio":  "prisma studio",
    "db:reset":   "prisma migrate reset --force",
    "generate":   "prisma generate",
    "postinstall":"prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcrypt":         "^5.1.1",
    "cors":           "^2.8.5",
    "dotenv":         "^16.4.4",
    "express":        "^4.18.3",
    "helmet":         "^7.1.0",
    "jsonwebtoken":   "^9.0.2",
    "morgan":         "^1.10.0"
  },
  "devDependencies": {
    "@types/bcrypt":       "^5.0.2",
    "@types/cors":         "^2.8.17",
    "@types/express":      "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan":       "^1.9.9",
    "@types/node":         "^20.11.0",
    "prisma":              "^5.10.0",
    "ts-node":             "^10.9.2",
    "ts-node-dev":         "^2.0.0",
    "typescript":          "^5.3.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
